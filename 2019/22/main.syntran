
use ../../utils::*;
//use ../../dict_i64_2026 as dict_i64;

//==============================================================================

fn part1(args: &const Args): str
{
	let sum_ = 0'i64;

	let deck = [0: 10'i64];
	if (args.input_filename == "input.txt") deck = [0: 10_007'i64];

	let lines = readlns_(args.input_filename);
	apply_shuffle_process(&deck, &lines);

	sum_ = 0;
	while true
	{
		if (deck[sum_] == 2019) break;
		sum_ += 1;
	}

	println("part 1 = ", sum_);
	return str(sum_);
}

fn apply_shuffle_process(deck: &[i64; :], lines: &[str; :])
{
	const N = size(deck);
	for str_ in lines
	{
		//println("deck = ", deck);
		//println("str_ = ", str_);

		if starts_with_(str_, "deal into")
			// Reverse
			deck = deck[:-1:];
		else if starts_with_(str_, "cut")
		{
			let n = parse_i32(str_[3:]);
			//println("n = ", n);
			if n < 0
			{
				// Cut from end
				n = abs(n);
				deck = [deck[N-n:], deck[:N-n]];
			}
			else
				// Cut from beginning
				deck = [deck[n:], deck[:n]];
		}
		else if starts_with_(str_, "deal with increment")
		{
			let inc = parse_i32(str_[19:]);
			//println("inc = ", inc);

			deck[[0: inc: inc*N] % N] = deck;
		}
		else if starts_with_(str_, "Result:")
		{
			// Do nothing
		}
		else
		{
			println(ERROR_STR, "bad instruction """, str_, """");
			exit(1);
		}
	}
	return;
}

fn inv(a: i64, n: i64): i64
{
	return powmod(a, n-2, n);
}

fn part2(args: &const Args): str
{
	let sum_ = 0'i64;
	let la = 0'i64; let lb = 0'i64;

	// Straight from reddit: https://topaz.github.io/paste/#

	const n = 119_315_717_514_047;
	const c = 2020'i64;
	let a = 1'i64; let b = 0'i64;
	let lines = readlns_(args.input_filename);
	for str_ in lines {
		if starts_with_(str_, "deal into") {
			la = -1; lb = -1;
		} else if starts_with_(str_, "deal with increment") {
			la = parse_i32(str_[19:]); lb = 0;
		} else if starts_with_(str_, "cut") {
			let n = parse_i32(str_[3:]);
			la = 1; lb = -n;
		}
		a = (la * a) % n;
		b = (la * b + lb) % n;
	}
	//println("a, b = ", [a, b]);
	const M = 101_741_582_076_661;

	let Ma = powmod(a, M, n);
	let Mb = mulmod(mulmod(b, Ma-1, n), inv(a-1,n), n);
	sum_ = mulmod(c-Mb, inv(Ma,n), n);

	// Finally! I probably tried the correct combination of code here (it was
	// commented-out) but the key was also using positive modulus (pmod64) in
	// the implementations of mulmod() and powmod(), which I had not tried
	// before

	println("part 2 = ", sum_);
	return str(sum_);
}

